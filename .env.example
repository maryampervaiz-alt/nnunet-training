# ─── Environment Template ──────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your machine.
#   cp .env.example .env
#
# Every configurable value in this pipeline is controlled from this file.
# No values are hardcoded in any Python script or notebook cell.

# Root of this repository (used to construct relative paths below)
PROJECT_ROOT=/path/to/nnunet-men-rt

# ─── nnU-Net Required Paths ───────────────────────────────────────────────────
# These three variables are mandatory for all nnU-Net commands.
nnUNet_raw=${PROJECT_ROOT}/nnunet_raw
nnUNet_preprocessed=${PROJECT_ROOT}/nnunet_preprocessed
nnUNet_results=${PROJECT_ROOT}/nnunet_results

# ─── Dataset ──────────────────────────────────────────────────────────────────
# Integer ID used in the nnU-Net folder name: 001 → Dataset001_BraTSMENRT
DATASET_ID=001
DATASET_NAME=BraTSMENRT

# Source data — zip files or extracted directories (auto-detected)
TRAIN_SOURCE=${PROJECT_ROOT}/BraTs MEN-RT/BraTS2024-MEN-RT-TrainingData.zip
VAL_SOURCE=${PROJECT_ROOT}/BraTs MEN-RT/BraTS2024-MEN-RT-ValidationData.zip

# Suffix that identifies the GTV label file inside each case folder
# BraTS MEN-RT convention: BraTS-MEN-RT-XXXX-Y_gtv.nii.gz
LABEL_SUFFIX=gtv

# Maximum number of training cases to use (pilot subset).
# Set to full dataset size (e.g. 500) for production training.
# 20 = quick pilot run (~2-4 h on T4 GPU)
MAX_TRAIN_CASES=20

# ─── Training ─────────────────────────────────────────────────────────────────
# nnU-Net configuration — nnU-Net auto-selects all model hyperparameters
NNUNET_CONFIGURATION=3d_fullres
NNUNET_PLANS_IDENTIFIER=nnUNetPlans

# Trainer class
NNUNET_TRAINER_CLASS=nnUNetTrainerEarlyStopping

# Number of cross-validation folds
NUM_FOLDS=5

# Epochs per fold.
# 10  = sanity check / pipeline validation
# 50  = meaningful pilot results
# 300 = strong preliminary results
# 1000 = full training (publication quality)
NNUNET_NUM_EPOCHS=10

# Target epochs when resuming an interrupted training run.
# Must be >= NNUNET_NUM_EPOCHS from the original run.
RESUME_TARGET_EPOCHS=50

# ─── Reproducibility ──────────────────────────────────────────────────────────
# Global random seed applied to Python, NumPy, PyTorch, and CUDA.
NNUNET_SEED=42

# ─── Early Stopping ───────────────────────────────────────────────────────────
# Epochs without improvement before stopping (0 = disabled)
ES_PATIENCE=50
# Minimum Dice improvement to reset patience counter
ES_MIN_DELTA=0.0001
# Epochs at start of training where early stopping is inactive
# Note: if NNUNET_NUM_EPOCHS <= ES_WARMUP, early stopping never triggers.
# This is correct for short pilot runs — ES activates only in full training.
ES_WARMUP=50

# ─── Inference ────────────────────────────────────────────────────────────────
# Sliding-window overlap (0 < step_size <= 1). Higher = more accurate, slower.
INFERENCE_STEP_SIZE=0.5
# Disable test-time augmentation for faster inference (set true for speed)
INFERENCE_DISABLE_TTA=false
# Inference device
INFERENCE_DEVICE=cuda

# ─── Post-processing ──────────────────────────────────────────────────────────
# Comma-separated list of connected-component size thresholds to sweep.
# The best value is selected on the validation set and reported in the paper.
PP_THRESHOLDS=10,25,50,100,200,500

# ─── Evaluation ───────────────────────────────────────────────────────────────
# BraTS 2024 MEN-RT official NSD surface tolerance (mm)
NSD_TOLERANCE_MM=2.0
# Cases with DSC below this value are flagged as outliers
LOW_DICE_THRESHOLD=0.5
# Bootstrap resamples for 95% confidence intervals
BOOTSTRAP_N=2000

# ─── Hardware ─────────────────────────────────────────────────────────────────
# GPU device index/es (comma-separated for multi-GPU, e.g. "0,1")
CUDA_VISIBLE_DEVICES=0
# Number of data augmentation workers (reduce if Kaggle subprocess hangs)
NNUNET_N_PROC_DA=4
# Disable torch.compile to avoid ~30 min JIT overhead on first epoch.
# Set to true for full training (faster after compilation).
NNUNET_COMPILE=false

# ─── Experiment Tracking ──────────────────────────────────────────────────────
EXPERIMENT_NAME=BraTSMENRT_baseline
MLFLOW_TRACKING_URI=${PROJECT_ROOT}/experiments/mlruns

# ─── Kaggle-specific ──────────────────────────────────────────────────────────
# Output directory for saving checkpoints between Kaggle sessions.
# /kaggle/working/outputs is preserved as downloadable notebook output.
KAGGLE_OUTPUT_DIR=/kaggle/working/outputs
