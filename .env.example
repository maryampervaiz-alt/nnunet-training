# ─── Environment Template ──────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your machine.
#   cp .env.example .env

# Root of this repository (used to construct relative paths below)
PROJECT_ROOT=/path/to/nnunet-men-rt

# ─── nnU-Net Required Paths ───────────────────────────────────────────────────
# These three variables are mandatory for all nnU-Net commands.
nnUNet_raw=${PROJECT_ROOT}/nnunet_raw
nnUNet_preprocessed=${PROJECT_ROOT}/nnunet_preprocessed
nnUNet_results=${PROJECT_ROOT}/checkpoints

# ─── Dataset ──────────────────────────────────────────────────────────────────
# Integer ID used in the nnU-Net folder name: e.g. 001 → Dataset001_BraTSMENRT
DATASET_ID=001
DATASET_NAME=BraTSMENRT

# Source data — can be zip files or extracted directories (auto-detected).
TRAIN_SOURCE=${PROJECT_ROOT}/BraTs MEN-RT/BraTS2024-MEN-RT-TrainingData.zip
VAL_SOURCE=${PROJECT_ROOT}/BraTs MEN-RT/BraTS2024-MEN-RT-ValidationData.zip

# Suffix that identifies the GTV label file inside each case folder.
# BraTS MEN-RT convention: BraTS-MEN-RT-XXXX-Y_gtv.nii.gz
LABEL_SUFFIX=gtv

# ─── Training ─────────────────────────────────────────────────────────────────
# nnU-Net configuration (nnU-Net auto-selects hyperparameters — do not override)
NNUNET_CONFIGURATION=3d_fullres
NNUNET_PLANS_IDENTIFIER=nnUNetPlans

# Trainer class — use nnUNetTrainerEarlyStopping for built-in early stopping
NNUNET_TRAINER_CLASS=nnUNetTrainerEarlyStopping

# Number of cross-validation folds
NUM_FOLDS=5

# ─── Reproducibility ──────────────────────────────────────────────────────────
# Global random seed applied to Python, NumPy, PyTorch, and CUDA.
# Propagated to subprocesses via NNUNET_SEED env var.
NNUNET_SEED=42

# ─── Early Stopping ───────────────────────────────────────────────────────────
# Number of epochs without improvement before stopping (0 = disabled)
ES_PATIENCE=50
# Minimum Dice improvement required to reset the patience counter
ES_MIN_DELTA=0.0001
# Epochs at the start of training during which early stopping is inactive
ES_WARMUP=50

# ─── Hardware ─────────────────────────────────────────────────────────────────
# GPU device index/es (comma-separated for multi-GPU, e.g. "0,1")
CUDA_VISIBLE_DEVICES=0

# ─── Experiment Tracking ──────────────────────────────────────────────────────
EXPERIMENT_NAME=BraTSMENRT_baseline
MLFLOW_TRACKING_URI=${PROJECT_ROOT}/experiments/mlruns
